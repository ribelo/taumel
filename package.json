{
  "name": "taumel",
  "private": true,
  "type": "module",
  "pi": {
    "extensions": [
      "./dist/extension.js"
    ]
  },
  "scripts": {
    "build": "npm run build:ocaml && npm run build:extension",
    "build:extension": "sh scripts/build-extension.sh",
    "typecheck": "tsc",
    "ocaml:init": "nix develop -c taumel-opam-init",
    "build:ocaml": "nix develop -c sh scripts/build-ocaml.sh",
    "test:ocaml": "nix develop -c sh -c 'node scripts/generate-contract-bindings.mjs && dune runtest'",
    "smoke:artifact": "nix develop -c node test/smoke_artifact.mjs",
    "smoke:extension-artifact": "bun test/smoke_extension_artifact.mjs",
    "smoke:path-authorization": "nix develop -c node test/smoke_path_authorization.mjs",
    "smoke:view-media-resolution": "nix develop -c node test/smoke_view_media_resolution.mjs",
    "smoke:tool-contracts": "bun test/smoke_tool_contracts.mjs",
    "smoke:tool-metadata-requirements": "bun test/smoke_tool_metadata_requirements.mjs",
    "smoke:agent-contracts": "bun test/smoke_agent_contracts.mjs",
    "smoke:agent-lifecycle": "nix develop -c node test/smoke_agent_lifecycle.mjs",
    "smoke:agent-child-session-cleanup": "bun test/smoke_agent_child_session_cleanup.mjs",
    "smoke:agent-runs-manager": "bun test/smoke_agent_runs_manager.mjs",
    "smoke:agent-async": "bun test/smoke_agent_async.mjs",
    "smoke:agent-worktrees": "bun test/smoke_agent_worktrees.mjs",
    "smoke:agent-worktree-runtime": "node --experimental-loader ./test/markdown-loader.mjs test/smoke_agent_worktree_runtime.mjs",
    "smoke:exa-contracts": "bun test/smoke_exa_contracts.mjs",
    "smoke:cron-loop": "bun test/smoke_cron_loop.mjs",
    "smoke:cron-persistence": "bun test/smoke_cron_persistence.mjs",
    "smoke:compaction-model": "bun test/smoke_compaction_model.mjs",
    "smoke:tool-renderers": "bun test/smoke_tool_renderers.mjs",
    "smoke:exec-notifications": "bun test/smoke_exec_notifications.mjs",
    "smoke:prepared-exec-contract": "bun test/smoke_prepared_exec_contract.mjs",
    "smoke:authority-plans": "node test/smoke_authority_plans.mjs",
    "smoke:exec-pty": "node --experimental-loader ./test/markdown-loader.mjs test/smoke_exec_pty.mjs",
    "smoke:gateway-registration": "bun test/smoke_gateway_registration.mjs",
    "smoke:global-settings": "bun test/smoke_global_settings.mjs",
    "smoke:visibility-manager": "bun test/smoke_visibility_manager.mjs",
    "smoke:goal-commands": "bun test/smoke_goal_commands.mjs",
    "smoke:usage-inspection": "bun test/smoke_usage_inspection.mjs",
    "smoke:bridge-contracts": "bun test/smoke_bridge_contracts.mjs",
    "smoke:thinking-shortcuts": "bun test/smoke_thinking_shortcuts.mjs",
    "smoke:util": "bun test/smoke_util.mjs",
    "check:typed-boundaries": "node test/check_typed_boundaries.mjs",
    "check:source-file-sizes": "node test/check_source_file_sizes.mjs",
    "gate": "npm run typecheck && npm run check:typed-boundaries && npm run check:source-file-sizes && npm run build && npm run test:ocaml && npm run smoke:artifact && npm run smoke:extension-artifact && npm run smoke:path-authorization && npm run smoke:view-media-resolution && npm run smoke:tool-contracts && npm run smoke:tool-metadata-requirements && npm run smoke:agent-contracts && npm run smoke:agent-lifecycle && npm run smoke:agent-child-session-cleanup && npm run smoke:agent-runs-manager && npm run smoke:agent-async && npm run smoke:agent-worktrees && npm run smoke:agent-worktree-runtime && npm run smoke:exa-contracts && npm run smoke:cron-loop && npm run smoke:cron-persistence && npm run smoke:compaction-model && npm run smoke:tool-renderers && npm run smoke:exec-notifications && npm run smoke:prepared-exec-contract && npm run smoke:authority-plans && npm run smoke:exec-pty && npm run smoke:gateway-registration && npm run smoke:global-settings && npm run smoke:visibility-manager && npm run smoke:goal-commands && npm run smoke:usage-inspection && npm run smoke:bridge-contracts && npm run smoke:thinking-shortcuts && npm run smoke:util"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.9",
    "@earendil-works/pi-tui": "^0.79.9",
    "@silvia-odwyer/photon-node": "^0.3.4",
    "diff": "^9.0.0",
    "node-pty": "^1.1.0",
    "tree-sitter": "^0.21.1",
    "tree-sitter-bash": "^0.23.3",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@ocsigen/ts2ocaml": "^1.4.6",
    "typescript": "^6.0.3"
  }
}
